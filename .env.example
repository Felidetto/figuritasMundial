# Supabase (legacy — soportados)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (alias opcionales — equivalentes a los anteriores)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_SECRET_KEY=your-secret-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (expiración de reservas — Vercel Cron envía Authorization: Bearer)
CRON_SECRET=generate-a-random-secret

# Admin local (opcional — solo para pruebas E2E automatizadas)
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
