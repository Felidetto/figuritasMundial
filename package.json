{
  "name": "laminas-2026",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "pnpm typecheck && pnpm lint && pnpm test",
    "db:types": "supabase gen types typescript --linked > src/types/database.ts",
    "db:verify": "node scripts/db-verify.mjs",
    "db:seed:catalog": "supabase db query --linked -f supabase/seed-remote-catalog.sql",
    "sync:catalog": "pnpm db:seed:catalog",
    "setup:env": "node scripts/setup-local-env.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "stock:test-setup": "node scripts/set-test-stock.mjs",
    "test:smoke": "playwright test tests/e2e/local-smoke.spec.ts",
    "test:smoke:prod": "playwright test --config playwright.prod.config.ts",
    "vercel:env": "node scripts/sync-vercel-env.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
